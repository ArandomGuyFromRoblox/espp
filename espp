-- === Toggleable Player Outline ESP (Team + Friend Colors FIXED FULL SCRIPT) ===

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local ESP_ENABLED = false
local HIGHLIGHT_NAME = "MyESPOutline"

-- Colors
local FRIEND_COLOR = Color3.fromRGB(0, 170, 255)   -- Blue
local TEAM_COLOR = Color3.fromRGB(0, 255, 0)       -- Green
local ENEMY_COLOR = Color3.fromRGB(255, 0, 0)      -- Red

-- Your friend list (UserIds)
local FRIEND_USERIDS = {
    [220699362] = true,
}

-- Get correct color
local function getColor(player)
    if not player then return ENEMY_COLOR end

    -- Friend check (works in Studio + real game)
    if FRIEND_USERIDS[player.UserId] or LocalPlayer:IsFriendsWith(player.UserId) then
        return FRIEND_COLOR
    end

    -- Team check
    if player.Team ~= nil and LocalPlayer.Team ~= nil then
        if player.Team == LocalPlayer.Team then
            return TEAM_COLOR
        end
    end

    return ENEMY_COLOR
end

-- Apply / update highlight
local function applyHighlight(character)
    if not character then return end

    local player = Players:GetPlayerFromCharacter(character)
    if not player then return end

    local highlight = character:FindFirstChild(HIGHLIGHT_NAME)

    if not ESP_ENABLED then
        if highlight then highlight:Destroy() end
        return
    end

    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = HIGHLIGHT_NAME
        highlight.Adornee = character
        highlight.FillTransparency = 1
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = character
    end

    highlight.OutlineColor = getColor(player)
end

-- Constant update loop (keeps colors correct live)
RunService.RenderStepped:Connect(function()
    if not ESP_ENABLED then return end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            applyHighlight(player.Character)
        end
    end
end)

-- Setup players
local function setupPlayer(player)
    player.CharacterAdded:Connect(function(character)
        applyHighlight(character)
    end)

    if player.Character then
        applyHighlight(player.Character)
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    setupPlayer(player)
end

Players.PlayerAdded:Connect(setupPlayer)

-- Toggle ESP
local function toggleESP()
    ESP_ENABLED = not ESP_ENABLED

    StarterGui:SetCore("SendNotification", {
        Title = "ESP",
        Text = ESP_ENABLED and "Player outlines ENABLED" or "Player outlines DISABLED",
        Duration = 2,
    })

    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then
            applyHighlight(player.Character)
        end
    end
end

-- Keybind "+"
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Equals then
        toggleESP()
    end
end)

print("ESP Outline loaded! Press '+' to toggle.")
